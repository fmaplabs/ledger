# Convex deployment name (matches cloud/.env.local; dev is fast-ermine-429)
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=

# WorkOS client id for the same environment as the Convex deployment
# (npx convex env get WORKOS_CLIENT_ID from cloud/)
VITE_WORKOS_CLIENT_ID=
# This should be your Custom Authentication Domain in production
VITE_WORKOS_API_HOSTNAME=api.workos.com
