# Production build-time env for the web app.
#
# Copy to `.env.production` and fill in the production values. Vite loads
# `.env.production` automatically for `vite build` (mode=production) and INLINES
# every VITE_* value into the browser bundle. These are public by design — they
# ship to every visitor — so keep only non-secret values here.
#
# `.env.production` holds public values and is safe to commit. Put anything
# secret in `.env.production.local` (gitignored) instead — but note the WorkOS
# server secrets are NOT build-time; they are Worker secrets (see .dev.vars.example).

# --- WorkOS (client / browser) -------------------------------------------------

# Same value as the WORKOS_CLIENT_ID Worker secret. Public.
VITE_WORKOS_CLIENT_ID=client_REPLACE_WITH_PROD_CLIENT_ID

# In production this should be your WorkOS Custom Authentication Domain
# (e.g. auth.ledger.dev). Falls back to api.workos.com.
VITE_WORKOS_API_HOSTNAME=api.workos.com

# --- Convex --------------------------------------------------------------------

# VITE_CONVEX_URL is intentionally omitted. The production deploy runs the build
# via `convex deploy --cmd '...' --cmd-url-env-var-name VITE_CONVEX_URL`, which
# injects the PROD deployment URL into the build automatically. Setting it here
# would risk shipping a stale/dev Convex URL. Only set it manually if you build
# the frontend without the Convex deploy wrapper.
# VITE_CONVEX_URL=https://your-prod-deployment.convex.cloud

# Optional page title override.
# VITE_APP_TITLE=ledger
