#!/usr/bin/env bash
# Test stand-in for the ledger binary: record every invocation (cwd and
# argv) to $LEDGER_SHIM_LOG, answer `status` with canned JSON, exit 0.
echo "$PWD|$*" >> "${LEDGER_SHIM_LOG:?}"
if [ "$1" = "status" ]; then
  echo '{"project":"ledger","task":"main","trackedTodayMs":3600000,"lastHeartbeatMs":1751470000000,"idleThresholdMinutes":15}'
fi
exit 0
